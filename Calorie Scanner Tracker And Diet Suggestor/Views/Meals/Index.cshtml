@model IEnumerable<Calorie_Scanner_Tracker_And_Diet_Suggestor.Models.Meals>
@{
    ViewData["Title"] = "Meals";
    var mealType = ViewBag.MealType?.ToString()?.ToLower() ?? "breakfast";
    var eatenIds = ViewBag.EatenMealIds as List<int> ?? new List<int>();
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    body.dark-mode { background-color:#121212;color:#f1f1f1; }
    body.dark-mode .card { background-color:#1e1e1e;color:white; }
    .step-active { background-color: #d4edda !important; transition:0.4s ease; }
    #calorieRing { max-width:220px;margin:auto; }
    .checkmark { font-size:50px;color:green; display:none; animation:pop 0.5s ease; }
    @@keyframes pop {0%{transform:scale(0);}100%{transform:scale(1);}}
</style>

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>🍽 Meals</h3>
        <button id="themeToggle" class="btn btn-outline-secondary btn-sm">Toggle Theme</button>
    </div>

    <!-- Meal Type Buttons -->
    <div class="mb-4 text-center">
        <div class="btn-group">
            <a asp-controller="Meals" asp-action="Index" asp-route-type="breakfast"
               class="btn btn-info @(mealType=="breakfast"?"active":"")">☀️ Breakfast</a>
            <a asp-controller="Meals" asp-action="Index" asp-route-type="lunch"
               class="btn btn-warning @(mealType=="lunch"?"active":"")">🍽 Lunch</a>
            <a asp-controller="Meals" asp-action="Index" asp-route-type="dinner"
               class="btn btn-success @(mealType=="dinner"?"active":"")">🌙 Dinner</a>
        </div>
    </div>

    <!-- Filters & Search -->
    <form method="get" asp-action="Index" class="d-flex flex-column flex-sm-row justify-content-between gap-3 mb-4">
        <input type="hidden" name="type" value="@mealType" />
        <input type="text" class="form-control" name="searchTerm" value="@ViewBag.SearchTerm" placeholder="Search meals..." />
        <select class="form-select" name="sortBy">
            <option value="">Sort By</option>
            <option value="calories" @@(ViewBag.SortBy=="calories"?"selected":"")>Calories</option>
            <option value="protein" @@(ViewBag.SortBy=="protein"?"selected":"")>Protein</option>
            <option value="carbs" @@(ViewBag.SortBy=="carbs"?"selected":"")>Carbs</option>
            <option value="fats" @@(ViewBag.SortBy=="fats"?"selected":"")>Fats</option>
        </select>
        <input type="number" class="form-control" name="minCalories" placeholder="Min Cal" />
        <input type="number" class="form-control" name="maxCalories" placeholder="Max Cal" />
        <button type="submit" class="btn btn-primary">Apply</button>
    </form>

    <p class="text-center mb-3"><strong>Total Meals:</strong> @Model.Count()</p>

    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center">No meals available for this type.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4" id="mealsContainer">
            @foreach (var meal in Model)
            {
                <div class="col">
                    <div class="card shadow-lg rounded-3 h-100">
                        <img src="https://source.unsplash.com/300x200/?@mealType,healthy" class="card-img-top" />
                        <div class="card-body text-center">
                            <h5 class="card-title">@meal.Name</h5>
                            <p><strong>Calories:</strong> @meal.Calories kcal</p>
                            <p><strong>Protein:</strong> @meal.Protein g | <strong>Carbs:</strong> @meal.Carbs g | <strong>Fats:</strong> @meal.Fats g</p>
                            <div class="d-flex justify-content-center gap-2">
                                <button class="btn btn-primary btn-sm" onclick="addToTracker(@meal.Id)">
                                    @(eatenIds.Contains(meal.Id) ? "✅ Added" : "Add to Tracker")
                                </button>
                                <button class="btn btn-outline-info btn-sm" onclick="loadPreparationSteps(@meal.Id)">View Steps</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Pagination -->
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            <li class="page-item @(currentPage==1?"disabled":"")">
                <a class="page-link" href="@Url.Action("Index", new { type=mealType, page=currentPage-1 })">Previous</a>
            </li>
            @for (int i=1;i<=totalPages;i++)
            {
                <li class="page-item @(currentPage==i?"active":"")">
                    <a class="page-link" href="@Url.Action("Index", new { type=mealType, page=i })">@i</a>
                </li>
            }
            <li class="page-item @(currentPage==totalPages?"disabled":"")">
                <a class="page-link" href="@Url.Action("Index", new { type=mealType, page=currentPage+1 })">Next</a>
            </li>
        </ul>
    </nav>

    <!-- Add / Capture Buttons -->
    <div class="text-center mt-4 d-flex justify-content-center gap-3">
        <a asp-action="Create" class="btn btn-success btn-lg">➕ Add New Meal</a>
        <a asp-action="Capture" class="btn btn-secondary btn-lg">📸 Capture Meal</a>
    </div>

    <!-- Preparation Steps Modal -->
    <div class="modal fade" id="prepModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Preparation Steps</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body" id="prepStepsContent">Loading...</div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
    // Theme toggle
    if(localStorage.getItem("darkMode")=="true") document.body.classList.add("dark-mode");
    document.getElementById("themeToggle").addEventListener("click",()=>{
        document.body.classList.toggle("dark-mode");
        localStorage.setItem("darkMode",document.body.classList.contains("dark-mode"));
    });

    // Add meal to tracker
            async function addToTracker(mealId) {

            try {

                const response = await fetch("/Meals/CreateAjax", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json"
                    },
                    body: JSON.stringify({
                        mealId: mealId
                    })
                });

                if (!response.ok) {
                    const text = await response.text();
                    console.error("Server error:", text);
                    alert("Server error occurred.");
                    return;
                }

                const data = await response.json();

                if (data.success) {
                    alert("Meal added to tracker!");
                } else {
                    alert(data.message);
                }

            } catch (err) {
                console.error(err);
                alert("Unexpected error.");
            }
        }

    // Load preparation steps
    function loadPreparationSteps(mealId){
        fetch(`/Meals/PreparationSteps/${mealId}`).then(res=>res.text()).then(html=>{
            document.getElementById("prepStepsContent").innerHTML = html;
            new bootstrap.Modal(document.getElementById("prepModal")).show();
        });
    }
</script>
}