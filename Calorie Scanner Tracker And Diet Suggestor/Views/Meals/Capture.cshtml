@{
    ViewData["Title"] = "AI Meal Scanner";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    body.dark-mode {
        background-color: #121212;
        color: #f1f1f1;
    }

        body.dark-mode .card {
            background-color: #1e1e1e;
            color: white;
        }

    .step-active {
        background-color: #d4edda !important;
        transition: 0.4s ease;
    }

    #calorieRing {
        max-width: 220px;
        margin: auto;
    }

    .checkmark {
        font-size: 50px;
        color: green;
        display: none;
        animation: pop 0.5s ease;
    }

    @@keyframes pop {
        0% {
            transform: scale(0);
        }

        100% {
            transform: scale(1);
        }
    }
</style>

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3>🍽️ AI Meal Scanner</h3>
        <button id="themeToggle" class="btn btn-outline-secondary btn-sm">Toggle Theme</button>
    </div>

    <div class="card shadow p-4">

        <!-- Goal Settings -->
        <div class="mb-3">
            <label>Daily Calorie Goal:</label>
            <input type="number" id="calorieGoalInput" class="form-control" value="2000" />
        </div>

        <!-- Portion Multiplier -->
        <div class="mb-3">
            <label>Portion Size:</label>
            <select id="portionMultiplier" class="form-select">
                <option value="1">1x (Normal)</option>
                <option value="1.5">1.5x (Large)</option>
                <option value="2">2x (Double)</option>
            </select>
        </div>

        <!-- Multi Image -->
        <input type="file" id="imageInput" accept="image/*" multiple class="form-control mb-3" />

        <button id="analyzeBtn" class="btn btn-primary w-100 mb-3">Analyze Meal</button>

        <!-- Preview -->
        <div id="previewContainer" class="row"></div>

        <!-- AI Steps -->
        <div id="aiSteps" class="mt-3" style="display:none;">
            <ul class="list-group">
                <li class="list-group-item" id="step1">🔍 Detecting food...</li>
                <li class="list-group-item" id="step2">🧠 Running AI model...</li>
                <li class="list-group-item" id="step3">📊 Calculating macros...</li>
            </ul>
        </div>

        <!-- Progress -->
        <div id="loadingOverlay" class="mt-3" style="display:none;">
            <div class="progress">
                <div id="progressBar"
                     class="progress-bar progress-bar-striped progress-bar-animated"
                     style="width:0%">
                    0%
                </div>
            </div>
        </div>

        <!-- Success -->
        <div class="text-center mt-3">
            <div id="successCheck" class="checkmark">✔</div>
        </div>

        <!-- Results -->
        <div id="resultContainer" class="mt-4" style="display:none;">

            <h4>Nutrition Summary</h4>

            <div class="text-center mb-3">
                <canvas id="calorieRing"></canvas>
                <h5 id="calorieText"></h5>
                <small id="remainingCalories"></small>
            </div>

            <canvas id="macroChart"></canvas>
            <canvas id="macroPercentChart" class="mt-4"></canvas>

            <div id="nutritionResults" class="mt-4"></div>

            <div class="mt-3">
                <strong>AI Confidence:</strong>
                <span id="confidenceScore" class="badge bg-success"></span>
            </div>

            <button id="copyBtn" class="btn btn-outline-secondary mt-3 w-100">Copy Results</button>

            <div id="warningMessage" class="alert alert-warning mt-3" style="display:none;"></div>

            <button id="redirectBtn" class="btn btn-success mt-3 w-100">
                Go To My Meals (Auto in <span id="countdown">5</span>s)
            </button>

        </div>

        <div id="errorContainer" class="alert alert-danger mt-4" style="display:none;"></div>

    </div>
</div>

<audio id="successSound">
    <source src="https://actions.google.com/sounds/v1/cartoon/clang_and_wobble.ogg" type="audio/ogg">
</audio>

<script>
    let macroChartInstance, percentChartInstance, calorieChartInstance;

    const calorieGoalInput = document.getElementById("calorieGoalInput");

    // Load saved theme & goal
    if (localStorage.getItem("darkMode") === "true") {
        document.body.classList.add("dark-mode");
    }
    if (localStorage.getItem("calorieGoal")) {
        calorieGoalInput.value = localStorage.getItem("calorieGoal");
    }

    calorieGoalInput.addEventListener("change", () => {
        localStorage.setItem("calorieGoal", calorieGoalInput.value);
    });

    document.getElementById("themeToggle").addEventListener("click", () => {
        document.body.classList.toggle("dark-mode");
        localStorage.setItem("darkMode", document.body.classList.contains("dark-mode"));
    });

    document.getElementById("analyzeBtn").addEventListener("click", async function () {

        const files = document.getElementById("imageInput").files;
        if (!files.length) return showError("Select at least one image.");

        resetUI();
        simulateAISteps();
        simulateProgress();

        let totalCalories = 0, totalProtein = 0, totalCarbs = 0, totalFats = 0;

        for (let file of files) {

            previewImage(file);

            const formData = new FormData();
            formData.append("imageFile", file);

            const response = await fetch("/Meals/UploadImage", {
                method: "POST",
                body: formData
            });

            const data = await response.json();
            if (!response.ok) throw new Error(data.message);

            totalCalories += data.nutrition.calories;
            totalProtein += data.nutrition.protein;
            totalCarbs += data.nutrition.carbs;
            totalFats += data.nutrition.fats;

            if (data.warning) {
                document.getElementById("warningMessage").innerText = data.warning;
                document.getElementById("warningMessage").style.display = "block";
            }

            document.getElementById("confidenceScore").innerText =
                (data.confidence || 95) + "%";
        }

        const portion = parseFloat(document.getElementById("portionMultiplier").value);

        totalCalories *= portion;
        totalProtein *= portion;
        totalCarbs *= portion;
        totalFats *= portion;

        completeProgress();
        showSuccess();

        displayResults(totalCalories, totalProtein, totalCarbs, totalFats);
        autoRedirect();
    });

    function displayResults(calories, protein, carbs, fats) {

        const goal = parseInt(calorieGoalInput.value);

        document.getElementById("calorieText").innerText = calories + " kcal";
        document.getElementById("remainingCalories").innerText =
            "Remaining today: " + (goal - calories) + " kcal";

        drawCalorieRing(calories, goal);
        drawMacroChart(protein, carbs, fats);
        drawPercentChart(protein, carbs, fats);

        document.getElementById("nutritionResults").innerHTML = `
            <ul class="list-group">
                <li class="list-group-item">Protein: ${protein.toFixed(1)} g</li>
                <li class="list-group-item">Carbs: ${carbs.toFixed(1)} g</li>
                <li class="list-group-item">Fats: ${fats.toFixed(1)} g</li>
            </ul>
        `;

        document.getElementById("resultContainer").style.display = "block";
    }

    function drawCalorieRing(calories, goal) {
        if (calorieChartInstance) calorieChartInstance.destroy();

        calorieChartInstance = new Chart(document.getElementById("calorieRing"), {
            type: "doughnut",
            data: {
                labels: ["Consumed", "Remaining"],
                datasets: [{ data: [calories, Math.max(0, goal - calories)] }]
            },
            options: { cutout: "70%", plugins: { legend: { display: false } } }
        });
    }

    function drawMacroChart(p, c, f) {
        if (macroChartInstance) macroChartInstance.destroy();

        macroChartInstance = new Chart(document.getElementById("macroChart"), {
            type: "bar",
            data: {
                labels: ["Protein", "Carbs", "Fats"],
                datasets: [{ label: "Grams", data: [p, c, f] }]
            }
        });
    }

    function drawPercentChart(p, c, f) {
        if (percentChartInstance) percentChartInstance.destroy();

        percentChartInstance = new Chart(document.getElementById("macroPercentChart"), {
            type: "pie",
            data: {
                labels: ["Protein", "Carbs", "Fats"],
                datasets: [{ data: [p, c, f] }]
            }
        });
    }

    function simulateAISteps() {
        document.getElementById("aiSteps").style.display = "block";
        setTimeout(() => activateStep("step1"), 500);
        setTimeout(() => activateStep("step2"), 1500);
        setTimeout(() => activateStep("step3"), 2500);
    }

    function activateStep(id) {
        document.getElementById(id).classList.add("step-active");
    }

    function simulateProgress() {
        document.getElementById("loadingOverlay").style.display = "block";
        let bar = document.getElementById("progressBar");
        let width = 0;
        window.progressInterval = setInterval(() => {
            if (width >= 90) return;
            width += 5;
            bar.style.width = width + "%";
            bar.innerText = width + "%";
        }, 300);
    }

    function completeProgress() {
        clearInterval(window.progressInterval);
        let bar = document.getElementById("progressBar");
        bar.style.width = "100%";
        bar.innerText = "100%";
        setTimeout(() => document.getElementById("loadingOverlay").style.display = "none", 500);
    }

    function showSuccess() {
        document.getElementById("successCheck").style.display = "block";
        document.getElementById("successSound").play();
    }

    function autoRedirect() {
        let count = 5;
        let interval = setInterval(() => {
            count--;
            document.getElementById("countdown").innerText = count;
            if (count <= 0) {
                clearInterval(interval);
                window.location.href = "/Meals";
            }
        }, 1000);
    }

    function previewImage(file) {
        const reader = new FileReader();
        reader.onload = e => {
            document.getElementById("previewContainer").innerHTML +=
                `<div class="col-md-4 mb-2">
                    <img src="${e.target.result}" class="img-fluid rounded shadow"/>
                 </div>`;
        };
        reader.readAsDataURL(file);
    }

    function showError(msg) {
        const box = document.getElementById("errorContainer");
        box.innerText = msg;
        box.style.display = "block";
    }

    function resetUI() {
        document.getElementById("resultContainer").style.display = "none";
        document.getElementById("errorContainer").style.display = "none";
        document.getElementById("warningMessage").style.display = "none";
        document.getElementById("aiSteps").style.display = "none";
        document.getElementById("successCheck").style.display = "none";
        document.getElementById("previewContainer").innerHTML = "";
    }

    document.getElementById("copyBtn").addEventListener("click", () => {
        navigator.clipboard.writeText(document.getElementById("nutritionResults").innerText);
    });

    document.getElementById("redirectBtn").addEventListener("click", () => {
        window.location.href = "/Meals";
    });
</script>