@{
    ViewData["Title"] = "AI Meal Scanner";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>

    body.dark-mode {
        background: #121212;
        color: white;
    }

    .card {
        border-radius: 14px;
    }

    #cameraContainer {
        position: relative;
    }

    #camera {
        width: 100%;
        border-radius: 12px;
    }

    #overlayCanvas {
        position: absolute;
        top: 0;
        left: 0;
        pointer-events: none;
    }

    .detectBox {
        position: absolute;
        border: 3px solid #00ff88;
        border-radius: 6px;
        animation: pulse 1.3s infinite;
    }

    @@keyframes pulse {
        0%

    {
        border-color: #00ff88
    }

    50% {
        border-color: #00cc66
    }

    100% {
        border-color: #00ff88
    }

    }

    .step-active {
        background: #d4edda !important;
    }

    .checkmark {
        font-size: 50px;
        color: green;
        display: none;
    }

    #calorieRing {
        max-width: 200px;
        margin: auto;
    }

    .preview-img {
        border-radius: 10px;
    }

</style>


<div class="container py-4">

    <div class="d-flex justify-content-between mb-3">
        <h3>🍽️ AI Meal Scanner</h3>
        <button id="themeToggle" class="btn btn-outline-secondary btn-sm">Toggle Theme</button>
    </div>


    <div class="row">

        <!-- CAMERA -->
        <div class="col-lg-6">

            <div class="card p-3 shadow">

                <h5>📷 Live Camera</h5>

                <div id="cameraContainer">

                    <video id="camera" autoplay playsinline></video>
                    <canvas id="overlayCanvas"></canvas>

                </div>

                <button id="captureBtn" class="btn btn-success mt-3 w-100">
                    📸 Capture Meal
                </button>

                <hr>

                <input type="file" id="imageInput" accept="image/*" multiple class="form-control">

                <button id="analyzeBtn" class="btn btn-primary mt-3 w-100">
                    Analyze Uploaded Image
                </button>

                <div id="previewContainer" class="row mt-3"></div>

            </div>
        </div>



        <!-- RESULTS -->
        <div class="col-lg-6">

            <div class="card shadow p-4">

                <label>Daily Calorie Goal</label>
                <input type="number" id="calorieGoalInput" class="form-control mb-3" value="2000">

                <label>Portion Size</label>
                <select id="portionMultiplier" class="form-select mb-3">
                    <option value="1">Normal</option>
                    <option value="1.5">Large</option>
                    <option value="2">Double</option>
                </select>


                <div id="aiSteps" style="display:none">

                    <ul class="list-group mb-3">
                        <li class="list-group-item" id="step1">🔍 Detecting food</li>
                        <li class="list-group-item" id="step2">🧠 Running AI model</li>
                        <li class="list-group-item" id="step3">📊 Calculating nutrition</li>
                    </ul>

                </div>


                <div id="loadingOverlay" style="display:none">
                    <div class="progress">
                        <div id="progressBar" class="progress-bar progress-bar-striped progress-bar-animated" style="width:0%">0%</div>
                    </div>
                </div>


                <div class="text-center mt-3">
                    <div id="successCheck" class="checkmark">✔</div>
                </div>


                <div id="resultContainer" style="display:none">

                    <h4>Nutrition Summary</h4>

                    <canvas id="calorieRing"></canvas>

                    <h5 id="calorieText" class="text-center"></h5>
                    <small id="remainingCalories" class="d-block text-center mb-3"></small>

                    <canvas id="macroChart"></canvas>
                    <canvas id="macroPercentChart" class="mt-3"></canvas>

                    <div id="nutritionResults" class="mt-3"></div>

                    <div class="mt-3">
                        AI Confidence:
                        <span id="confidenceScore" class="badge bg-success"></span>
                    </div>

                    <button id="copyBtn" class="btn btn-outline-secondary mt-3 w-100">
                        Copy Results
                    </button>

                    <button id="redirectBtn" class="btn btn-success mt-3 w-100">
                        Go To My Meals
                    </button>

                </div>

                <div id="errorContainer" class="alert alert-danger mt-3" style="display:none"></div>

            </div>

        </div>

    </div>

</div>



<script>

    let macroChartInstance
    let percentChartInstance
    let calorieChartInstance

    const camera=document.getElementById("camera")
    const overlay=document.getElementById("overlayCanvas")
    const ctx=overlay.getContext("2d")

    let totalCalories=0
    let totalProtein=0
    let totalCarbs=0
    let totalFats=0


    // CAMERA START
    navigator.mediaDevices.getUserMedia({video:true})
    .then(stream=>{
    camera.srcObject=stream
    })


    // CAPTURE IMAGE
    document.getElementById("captureBtn").onclick=async()=>{

    const temp=document.createElement("canvas")
    temp.width=camera.videoWidth
    temp.height=camera.videoHeight

    const tctx=temp.getContext("2d")
    tctx.drawImage(camera,0,0)

    temp.toBlob(async(blob)=>{

    const formData=new FormData()
    formData.append("imageFile",blob,"capture.jpg")

    await analyzeImage(formData)

    })

    }


    // ANALYZE UPLOAD
    document.getElementById("analyzeBtn").onclick=async()=>{

    const files=document.getElementById("imageInput").files

    if(!files.length){
    showError("Select image first")
    return
    }

    for(let file of files){

    previewImage(file)

    const formData=new FormData()
    formData.append("imageFile",file)

    await analyzeImage(formData)

    }

    }


    // MAIN ANALYSIS
    async function analyzeImage(formData){

    resetProgress()

    simulateSteps()
    simulateProgress()

    let response
    let data

    try{

    response=await fetch("/Meals/UploadImage",{
    method:"POST",
    body:formData
    })

    data=await response.json()

    }catch(e){
    showError("AI server not responding")
    return
    }

    if(!response.ok){
    showError(data.message || "AI analysis failed")
    return
    }


    drawDetections(data.detections || [])

    totalCalories+=data.nutrition.calories
    totalProtein+=data.nutrition.protein
    totalCarbs+=data.nutrition.carbs
    totalFats+=data.nutrition.fats

    document.getElementById("confidenceScore").innerText=(data.confidence || 95)+"%"

    completeProgress()
    showSuccess()

    displayResults()

    }



    function drawDetections(detections){

    ctx.clearRect(0,0,overlay.width,overlay.height)

    overlay.width=camera.videoWidth
    overlay.height=camera.videoHeight

    if(!detections || detections.length===0){
        console.log("No detections returned from AI")
        return
    }

    detections.forEach(d=>{

    ctx.strokeStyle="#00ff88"
    ctx.lineWidth=3

    ctx.strokeRect(d.x,d.y,d.width,d.height)

    ctx.fillStyle="#00ff88"
    ctx.fillText(d.name,d.x,d.y-5)

    })

    }



    function displayResults(){

    const portion=parseFloat(document.getElementById("portionMultiplier").value)

    const calories=totalCalories*portion
    const protein=totalProtein*portion
    const carbs=totalCarbs*portion
    const fats=totalFats*portion

    const goal=parseInt(document.getElementById("calorieGoalInput").value)

    document.getElementById("resultContainer").style.display="block"

    document.getElementById("calorieText").innerText=calories+" kcal"

    document.getElementById("remainingCalories").innerText="Remaining: "+(goal-calories)

    drawCalorieRing(calories,goal)
    drawMacroChart(protein,carbs,fats)
    drawPercentChart(protein,carbs,fats)

    document.getElementById("nutritionResults").innerHTML=`
    <ul class="list-group">
    <li class="list-group-item">Protein ${protein.toFixed(1)} g</li>
    <li class="list-group-item">Carbs ${carbs.toFixed(1)} g</li>
    <li class="list-group-item">Fats ${fats.toFixed(1)} g</li>
    </ul>
    `

    }



    function drawCalorieRing(calories,goal){

    if(calorieChartInstance) calorieChartInstance.destroy()

    calorieChartInstance=new Chart(
    document.getElementById("calorieRing"),
    {
    type:"doughnut",
    data:{
    labels:["Consumed","Remaining"],
    datasets:[{
    data:[calories,Math.max(0,goal-calories)]
    }]
    },
    options:{
    cutout:"70%",
    plugins:{legend:{display:false}}
    }
    })

    }



    function drawMacroChart(p,c,f){

    if(macroChartInstance) macroChartInstance.destroy()

    macroChartInstance=new Chart(
    document.getElementById("macroChart"),
    {
    type:"bar",
    data:{
    labels:["Protein","Carbs","Fats"],
    datasets:[{label:"grams",data:[p,c,f]}]
    }
    })

    }



    function drawPercentChart(p,c,f){

    if(percentChartInstance) percentChartInstance.destroy()

    percentChartInstance=new Chart(
    document.getElementById("macroPercentChart"),
    {
    type:"pie",
    data:{
    labels:["Protein","Carbs","Fats"],
    datasets:[{data:[p,c,f]}]
    }
    })

    }



    function simulateSteps(){

    document.getElementById("aiSteps").style.display="block"

    setTimeout(()=>activate("step1"),500)
    setTimeout(()=>activate("step2"),1500)
    setTimeout(()=>activate("step3"),2500)

    }



    function activate(id){
    document.getElementById(id).classList.add("step-active")
    }



    function simulateProgress(){

    document.getElementById("loadingOverlay").style.display="block"

    let bar=document.getElementById("progressBar")
    let width=0

    window.progressInterval=setInterval(()=>{

    if(width>=90)return

    width+=5
    bar.style.width=width+"%"
    bar.innerText=width+"%"

    },300)

    }



    function completeProgress(){

    clearInterval(window.progressInterval)

    let bar=document.getElementById("progressBar")

    bar.style.width="100%"
    bar.innerText="100%"

    setTimeout(()=>{

    document.getElementById("loadingOverlay").style.display="none"

    },500)

    }



    function showSuccess(){

    document.getElementById("successCheck").style.display="block"

    }



    function previewImage(file){

    const reader=new FileReader()

    reader.onload=e=>{

    document.getElementById("previewContainer").innerHTML+=`
    <div class="col-4">
    <img src="${e.target.result}" class="img-fluid preview-img"/>
    </div>
    `

    }

    reader.readAsDataURL(file)

    }



    function showError(msg){

    const box=document.getElementById("errorContainer")

    box.innerText=msg
    box.style.display="block"

    }



    function resetProgress(){

    document.getElementById("errorContainer").style.display="none"
    document.getElementById("resultContainer").style.display="none"

    }



    document.getElementById("copyBtn").onclick=()=>{

    navigator.clipboard.writeText(
    document.getElementById("nutritionResults").innerText
    )

    }



    document.getElementById("redirectBtn").onclick=()=>{
    window.location="/Meals"
    }



    document.getElementById("themeToggle").onclick=()=>{

    document.body.classList.toggle("dark-mode")

    localStorage.setItem(
    "darkMode",
    document.body.classList.contains("dark-mode")
    )

    }

</script>