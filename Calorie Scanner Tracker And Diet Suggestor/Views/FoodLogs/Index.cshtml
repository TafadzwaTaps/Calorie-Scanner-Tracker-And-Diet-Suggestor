@model IEnumerable<Calorie_Scanner_Tracker_And_Diet_Suggestor.Models.FoodLog>

@{
    ViewData["Title"] = "Food Logs";
}

<h2 class="text-center fw-bold mb-4">@ViewData["Title"]</h2>

<div class="d-flex justify-content-between align-items-center mb-4">
    <a href="@Url.Action("Dashboard", "FoodLogs")" class="btn btn-success">
        <i class="bi bi-bar-chart-line"></i> My Dashboard
    </a>

    @if (User.IsInRole("Admin"))
    {
        <form class="d-flex align-items-center gap-2" method="get" action="@Url.Action("GetFoodLogsByUser", "FoodLogs")">
            <input type="number" name="userId" class="form-control" placeholder="Enter User ID..." required style="width: 200px;" />
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-search"></i> View User Logs
            </button>
        </form>
    }
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">No food logs found.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover shadow-sm">
            <thead class="table-light">
                <tr>
                    <th>User</th>
                    <th>Meal</th>
                    <th>Date Logged</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model)
                {
                    <tr>
                        <td>
                            <span class="badge bg-secondary">
                                @(log.User?.Username ?? "Unknown")
                            </span>
                        </td>
                        <td>
                            <span class="text-primary fw-semibold">
                                @(log.Meal?.Name ?? "Unknown Meal")
                            </span>
                        </td>
                        <td>@log.DateLogged.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <form asp-action="Delete" asp-route-id="@log.Id" method="post" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete log">
                                    <i class="bi bi-trash3-fill"></i> Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<div class="text-end mt-4">
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Add New Food Log
    </a>
</div>

<!-- Optional: Load Bootstrap Icons CDN for icons -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
