@model Calorie_Scanner_Tracker_And_Diet_Suggestor.Models.FoodLog

@{
    ViewData["Title"] = "Add Food Log";
}

<div class="container mt-5" style="max-width: 600px;">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">🍽 Log a Meal</h3>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label for="MealId" class="form-label"><strong>Select Meal:</strong></label>
                    <select asp-for="MealId" class="form-select" asp-items="ViewBag.Meals" required>
                        <option value="">-- Choose a Meal --</option>
                    </select>
                </div>

                <div class="d-flex justify-content-between">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-circle"></i> Log Meal
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left-circle"></i> Back to Logs
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Optional: Bootstrap Icons CDN -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">